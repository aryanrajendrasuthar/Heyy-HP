# HP Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables use the HP_ prefix.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
HP_APP_NAME=HP
HP_DEBUG=false

# ---------------------------------------------------------------------------
# Voice
# ---------------------------------------------------------------------------
HP_WAKE_PHRASE=Hey HP
HP_FOLLOW_UP_TIMEOUT_S=10
HP_AUDIO_SAMPLE_RATE=16000
# HP_AUDIO_DEVICE_INDEX=0   # Omit to use system default; set to mic device index if needed

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
HP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
HP_LOG_DIR=logs

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
HP_DB_PATH=data/hp.db
